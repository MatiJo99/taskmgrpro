// This is your Prisma schema definition
// https://www.prisma.io/docs/concepts/reference/prisma-schema-reference

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  tasks    Task[]
}

model Task {
  id          Int    @id @default(autoincrement())
  description String
  status      String @default("pending")
  user        User   @relation(fields: [userId], references: [id])
  userId      Int
}
